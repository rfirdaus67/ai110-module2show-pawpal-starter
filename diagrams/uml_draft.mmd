classDiagram

class Owner {
    +String name
    +String available_start
    +String available_end
    +Pet[] pets
    +add_pet(pet)
}

class Pet {
    +String name
    +String species
}

class Task {
    +String description
    +String time
    +int duration_minutes
    +int priority
    +Pet pet
    +bool completed
    +mark_complete()
}

class Planner {
    +Task[] tasks
    +add_task(task)
    +generate_plan(owner)
    +explain_plan()
    +get_total_duration()
}


Owner "1" --> "0..*" Pet : owns
Pet "1" --> "0..*" Task : has
Planner "1" --> "0..*" Task : manages
Planner ..> Owner : generates plan for